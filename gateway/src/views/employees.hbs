<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <title>FlixTube: Employees</title>

        <link rel="stylesheet" href="/css/tailwind.min.css">
        <link rel="stylesheet" href="/css/app.css">
    </head>
    <body class="bg-gray-50">
        <div class="flex flex-col">
            <div class="border-b-2 bg-gray-100">
                <div class="nav flex flex-row items-center mt-1 p-2">
                    <div class="text-xl font-bold">
                        FlixTube
                    </div>
                    <div class="ml-16">
                        <a href="/">Videos</a>
                    </div>
                    <div class="ml-4">
                        <a href="/upload">Upload</a>
                    </div>
                    <div class="ml-4">
                        <a href="/history">History</a>
                    </div>
                    <div class="ml-4 border-b-2 border-blue-600">
                        <a href="/employees">Employees</a>
                    </div>
                </div>
            </div>

            <div class="p-6 max-w-6xl w-full mx-auto">
                <h1 class="text-3xl font-bold mb-6">Employees</h1>

                {{#if error}}
                <div class="mb-4 p-3 border border-red-300 bg-red-100 text-red-800 rounded">
                    {{error}}
                </div>
                {{/if}}

                {{#if message}}
                <div class="mb-4 p-3 border border-green-300 bg-green-100 text-green-800 rounded">
                    {{message}}
                </div>
                {{/if}}

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div class="bg-white border rounded p-4 shadow-sm">
                        <h2 class="text-xl font-semibold mb-3">Create Employee</h2>

                        <form action="/employees" method="POST" class="space-y-3">
                            <div>
                                <label class="block mb-1 font-medium">ID</label>
                                <input
                                    class="w-full border rounded px-3 py-2"
                                    type="text"
                                    name="id"
                                    placeholder="11111111-1111-1111-1111-111111111111"
                                    required
                                >
                            </div>

                            <div>
                                <label class="block mb-1 font-medium">Name</label>
                                <input class="w-full border rounded px-3 py-2" type="text" name="name" required>
                            </div>

                            <div>
                                <label class="block mb-1 font-medium">Email</label>
                                <input class="w-full border rounded px-3 py-2" type="email" name="email" required>
                            </div>

                            <div>
                                <label class="block mb-1 font-medium">Role</label>
                                <input class="w-full border rounded px-3 py-2" type="text" name="role" required>
                            </div>

                            <div>
                                <label class="block mb-1 font-medium">Department</label>
                                <input class="w-full border rounded px-3 py-2" type="text" name="department" required>
                            </div>

                            <button class="bg-blue-600 text-white px-4 py-2 rounded" type="submit">
                                Create Employee
                            </button>
                        </form>
                    </div>

                    <div class="bg-white border rounded p-4 shadow-sm">
                        <h2 class="text-xl font-semibold mb-3">Find Employee by ID</h2>

                        <form action="/employees/{{searchId}}" method="GET" onsubmit="this.action='/employees/' + this.employeeId.value">
                            <div>
                                <label class="block mb-1 font-medium">Employee ID</label>
                                    <input
                                        class="w-full border rounded px-3 py-2"
                                        type="text"
                                        name="employeeId"
                                        value="{{searchId}}"
                                        placeholder="Enter employee id"
                                        required
                                    >
                            </div>

                            <button class="mt-3 bg-gray-800 text-white px-4 py-2 rounded" type="submit">
                                Search
                            </button>
                        </form>

                        {{#if selectedEmployee}}
                        <div class="mt-6 border-t pt-4">
                            <h3 class="text-lg font-semibold mb-2">Selected Employee</h3>
                            <div><strong>ID:</strong> {{selectedEmployee.id}}</div>
                            <div><strong>Name:</strong> {{selectedEmployee.name}}</div>
                            <div><strong>Email:</strong> {{selectedEmployee.email}}</div>
                            <div><strong>Role:</strong> {{selectedEmployee.role}}</div>
                            <div><strong>Department:</strong> {{selectedEmployee.department}}</div>
                        </div>
                        {{/if}}
                    </div>
                </div>

                <div class="bg-white border rounded p-4 shadow-sm mb-8">
                    <h2 class="text-xl font-semibold mb-3">All Employees</h2>

                    {{#if employeesList}}
                    <div class="overflow-x-auto">
                        <table class="min-w-full border border-gray-300">
                            <thead class="bg-gray-100">
                                <tr>
                                    <th class="border px-3 py-2 text-left">ID</th>
                                    <th class="border px-3 py-2 text-left">Name</th>
                                    <th class="border px-3 py-2 text-left">Email</th>
                                    <th class="border px-3 py-2 text-left">Role</th>
                                    <th class="border px-3 py-2 text-left">Department</th>
                                </tr>   
                            </thead>
                            <tbody>
                                {{#each employeesList}}
                                <tr>
                                    <td class="border px-3 py-2">
                                        <a class="text-blue-600 underline" href="/employees/{{id}}">
                                            {{id}}
                                        </a>
                                    </td>
                                    <td class="border px-3 py-2">{{name}}</td>
                                    <td class="border px-3 py-2">{{email}}</td>
                                    <td class="border px-3 py-2">{{role}}</td>
                                    <td class="border px-3 py-2">{{department}}</td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                    {{else}}
                    <p>No employees found.</p>
                    {{/if}}
                </div>

                {{#if selectedEmployee}}
                <div class="bg-white border rounded p-4 shadow-sm">
                    <h2 class="text-xl font-semibold mb-4">Edit or Delete Selected Employee</h2>

                    <form action="/employees/{{selectedEmployee.id}}/update" method="POST" class="space-y-3 mb-6">
                        <div>
                            <label class="block mb-1 font-medium">ID</label>
                            <input
                                class="w-full border rounded px-3 py-2 bg-gray-100"
                                type="text"
                                value="{{selectedEmployee.id}}"
                                disabled
                            >
                        </div>

                        <div>
                            <label class="block mb-1 font-medium">Name</label>
                            <input 
                                class="w-full border rounded px-3 py-2"
                                type="text"
                                name="name"
                                value="{{selectedEmployee.name}}"
                                required
                            >
                        </div>

                        <div>
                            <label class="block mb-1 font-medium">Email</label>
                            <input 
                                class="w-full border rounded px-3 py-2"
                                type="email"
                                name="email"
                                value="{{selectedEmployee.email}}"
                                required
                            >
                        </div>

                        <div>
                            <label class="block mb-1 font-medium">Role</label>
                            <input 
                                class="w-full border rounded px-3 py-2"
                                type="text"
                                name="role"
                                value="{{selectedEmployee.role}}"
                                required
                            >
                        </div>

                        <div>
                            <label class="block mb-1 font-medium">Department</label>
                            <input 
                                class="w-full border rounded px-3 py-2"
                                type="text"
                                name="department"
                                value="{{selectedEmployee.department}}"
                                required
                            >
                        </div>
                        
                        <button class="bg-yellow-500 text-white px-4 py-2 rounded" type="submit">
                            Update Employee
                        </button>
                    </form>
                </div>
                {{/if}}

               
            </div>
        </div>
    </body>
</html>